# Firebase Configuration - Android
FIREBASE_API_KEY_ANDROID=YOUR_ANDROID_API_KEY
FIREBASE_APP_ID_ANDROID=YOUR_ANDROID_APP_ID
FIREBASE_MESSAGING_SENDER_ID=YOUR_MESSAGING_SENDER_ID
FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID
FIREBASE_STORAGE_BUCKET=YOUR_STORAGE_BUCKET

# Firebase Configuration - iOS
FIREBASE_API_KEY_IOS=YOUR_IOS_API_KEY
FIREBASE_APP_ID_IOS=YOUR_IOS_APP_ID
FIREBASE_IOS_CLIENT_ID=YOUR_IOS_CLIENT_ID
FIREBASE_IOS_BUNDLE_ID=com.example.musplay

# Firebase Configuration - Web
FIREBASE_API_KEY_WEB=YOUR_WEB_API_KEY
FIREBASE_APP_ID_WEB=YOUR_WEB_APP_ID
FIREBASE_AUTH_DOMAIN=YOUR_AUTH_DOMAIN
FIREBASE_MEASUREMENT_ID_WEB=YOUR_WEB_MEASUREMENT_ID

# Firebase Configuration - Windows
FIREBASE_API_KEY_WINDOWS=YOUR_WINDOWS_API_KEY
FIREBASE_APP_ID_WINDOWS=YOUR_WINDOWS_APP_ID
FIREBASE_MEASUREMENT_ID_WINDOWS=YOUR_WINDOWS_MEASUREMENT_ID

# Firebase Configuration - macOS
FIREBASE_API_KEY_MACOS=YOUR_MACOS_API_KEY
FIREBASE_APP_ID_MACOS=YOUR_MACOS_APP_ID

# Google Sign In - Web Client ID (CRÍTICO para Android)
# Obtén este valor de: Google Cloud Console → APIs y Servicios → Credenciales
# Busca el OAuth Client ID de tipo "Web application"
GOOGLE_WEB_CLIENT_ID=YOUR_GOOGLE_WEB_CLIENT_ID

# Copiar este archivo a .env y reemplazar los valores con tus credenciales reales
# NO COMITEAR .env a control de versiones público